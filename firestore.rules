rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function renderedBookFieldsUnchanged() {
      return request.resource.data.pageWidth == resource.data.pageWidth
        && request.resource.data.pageHeight == resource.data.pageHeight
        && request.resource.data.orientation == resource.data.orientation
        && request.resource.data.layoutVersion == resource.data.layoutVersion
        && request.resource.data.trimSizeInches == resource.data.trimSizeInches
        && request.resource.data.totalPngBytes == resource.data.totalPngBytes
        && request.resource.data.pdfBytes == resource.data.pdfBytes
        && request.resource.data.pdfStoragePath == resource.data.pdfStoragePath
        && request.resource.data.pdfURL == resource.data.pdfURL
        && request.resource.data.pdfPageCount == resource.data.pdfPageCount
        && request.resource.data.renderStatus == resource.data.renderStatus
        && request.resource.data.renderedAt == resource.data.renderedAt;
    }

    function canUpdateBookVersion() {
      return !(resource.data.renderStatus == "rendered") || renderedBookFieldsUnchanged();
    }

    // All user content remains namespaced under users/{uid}/...
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /memories/{memoryId} {
        allow read, write: if isOwner(userId);
      }

      match /books/{bookId} {
        allow read, write: if isOwner(userId);
      }

      match /profiles/{profileId} {
        allow read, write: if isOwner(userId);
      }

      // Per-user dev cost rollups (DevCostTelemetryService) — YYYY-MM-dd doc ids.
      match /apiTelemetry/{dayKey} {
        allow read, write: if isOwner(userId);
      }

      // Server-only AI usage quota counters (aiProxy.js checkAndIncrementQuota).
      // Never client-writable — a client could otherwise reset/inflate its own quota.
      match /aiUsage/{usageId} {
        allow read, write: if false;
      }

      match /bookVersions/{bookVersionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
        allow update: if isOwner(userId) && canUpdateBookVersion();
      }

      // Cloud storybook AI jobs (client creates; Cloud Function updates; client marks complete).
      match /storybookJobs/{jobId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /orders/{orderId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      match /paidBookCheckouts/{paidCheckoutId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    match /config/pricing {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Global developer telemetry aggregates across all users.
    // Dashboard reads from these docs; DevCostTelemetryService (iOS) increments them client-side
    // via merge-set with FieldValue.increment on a fixed field set — writes are scoped to that
    // known schema so an authenticated client can't inject unrelated top-level fields into a
    // doc shared across every user. This does not bound the *values* an authenticated client can
    // increment by (Firestore rules only see the post-increment result) — the real fix is moving
    // these writes server-side; tracked as a follow-up, not implemented here.
    match /globalApiTelemetry/{dayKey} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "dayKey", "dateStart", "totalRequests", "successfulRequests", "failedRequests",
          "totalDurationMs", "totalPromptCharacters", "totalInputTokens", "totalOutputTokens",
          "totalInputImages", "totalOutputImages", "totalUploadedBytes",
          "estimatedCostLow", "estimatedCostBase", "estimatedCostHigh", "confidenceWeightedSum",
          "providerCounts", "providerCostBase", "modelCounts", "modelCostBase",
          "lastUpdated", "lastUserId"
        ]);
      allow delete: if false;
    }

    match /globalApiTelemetryTotals/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "totalRequests", "successfulRequests", "failedRequests",
          "estimatedCostLow", "estimatedCostBase", "estimatedCostHigh",
          "providerCounts", "providerCostBase", "modelCounts", "modelCostBase",
          "totalOutputImages", "totalInputImages", "totalUploadedBytes",
          "lastUpdated", "lastUserId"
        ]);
      allow delete: if false;
    }
  }
}
