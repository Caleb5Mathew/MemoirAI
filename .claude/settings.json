{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(cp:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npm run:*)",
      "Bash(xattr:*)",
      "Bash(sudo xattr:*)",
      "WebSearch",
      "mcp__xcode-tools__BuildProject",
      "mcp__xcode-tools__RunAllTests",
      "mcp__xcode-tools__RunSomeTests",
      "mcp__xcode-tools__GetBuildLog",
      "mcp__xcode-tools__DocumentationSearch",
      "mcp__xcode-tools__RenderPreview",
      "mcp__xcode-tools__XcodeRead",
      "mcp__xcode-tools__XcodeWrite",
      "mcp__xcode-tools__XcodeUpdate",
      "mcp__xcode-tools__XcodeGrep",
      "mcp__xcode-tools__XcodeGlob",
      "mcp__xcode-tools__XcodeListNavigatorIssues"
    ],
    "deny": [
      "Bash(firebase deploy:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__xcode-tools__XcodeWrite|mcp__xcode-tools__XcodeUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"[hook] Swift file written via Xcode MCP — run BuildProject to verify it compiles cleanly\"'"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'file=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get(\\\"file_path\\\",\\\"\\\"))\" 2>/dev/null); if echo \"$file\" | grep -q \"/functions/\"; then echo \"[hook] Cloud Function modified — verify with: cd functions && node -e \\\"require(\\\\\\\"./index\\\\\\\")\\\"\"; fi; exit 0'"
          }
        ]
      }
    ]
  }
}
