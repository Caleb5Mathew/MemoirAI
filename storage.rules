rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Canonical hybrid artifacts: PNG pages + packaged PDF per book version.
    match /users/{userId}/bookVersions/{bookVersionId}/pages/{pageFile} {
      allow read, write, delete: if isOwner(userId)
        && pageFile.matches('page_[0-9]{3}\\.png');
    }

    match /users/{userId}/bookVersions/{bookVersionId}/book.pdf {
      allow read, write, delete: if isOwner(userId);
    }

    // Family and friends: an unrevoked grant unlocks streaming the owner's memory audio.
    // Must precede the catch-all so this read rule wins for audio files.
    match /users/{userId}/audio/{audioFile} {
      allow read: if isOwner(userId)
        || (request.auth != null
            && firestore.exists(/databases/(default)/documents/users/$(userId)/accessGrants/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/users/$(userId)/accessGrants/$(request.auth.uid)).data.revoked != true);
      allow write, delete: if isOwner(userId);
    }

    // Backward-compatibility paths for older uploads.
    match /users/{userId}/{allPaths=**} {
      allow read, write, delete: if isOwner(userId);
    }
  }
}
