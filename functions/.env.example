# Copy to functions/.env for local emulator / deploy-time env (do not commit .env).
# Firebase Functions v2 loads .env on deploy when present.

# Comma-separated Firebase Auth emails allowed for adminListPrintOrders, fulfillOrder, adminListUserBooks
ADMIN_EMAILS=you@example.com

# false = paid orders wait for Print Ops UI (recommended). true = immediate Lulu submit on payment.
AUTO_FULFILL_PAID_ORDERS=false

# false = payment/AI callables accept requests without an App Check token (default until the
# iOS App Check SDK ships). true = reject callable requests missing a valid App Check token.
# See APP_CHECK_ROLLOUT section in STRIPE_GO_LIVE_CHECKLIST.md before flipping this.
ENFORCE_APP_CHECK=false
